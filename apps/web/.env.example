# Browser (public — inlined into the client bundle)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key>

# Server only (NEVER prefixed NEXT_PUBLIC_)
# Supabase JWT secret (legacy HS256) used to verify access tokens locally.
SUPABASE_JWT_SECRET=<jwt secret>
# Session pooler URI (direct connections are IPv6-only and unreachable).
DATABASE_URL=postgresql://postgres.<project-ref>:<url-encoded-password>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
