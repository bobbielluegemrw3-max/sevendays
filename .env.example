# Seven Days Derby — environment template
# Copy to .env.local (never commit real values).
#
# SECURITY (01_CONSTITUTION / 08_INFRASTRUCTURE):
# - SUPABASE_SERVICE_ROLE_KEY is Cloud Run / trusted server-side ONLY.
#   It must NEVER appear in browser code, client bundles, or logs.
# - Wallet keys live in Google Secret Manager only — never in .env files.

# --- Supabase ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
# Server-side only:
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
# Direct Postgres connection (migrations / workers):
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# --- App ---
JWT_SECRET=YOUR_JWT_SECRET

# --- Google Cloud (Phase 12+) ---
GCP_PROJECT_ID=
PUBSUB_EMULATOR_HOST=
