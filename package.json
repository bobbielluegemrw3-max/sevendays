{
  "name": "sevendays",
  "private": true,
  "packageManager": "pnpm@10.18.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check:forbidden-apis": "node scripts/check-forbidden-apis.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yaml,yml}\""
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "prettier": "^3.5.3",
    "supabase": "^2.109.0",
    "turbo": "^2.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "supabase",
      "esbuild"
    ]
  }
}
